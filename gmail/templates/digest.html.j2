<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  body { margin: 0; padding: 20px; background: #f0f4f8; font-family: Arial, sans-serif; }
  .wrap { max-width: 680px; margin: 0 auto; }
  .header { background: #1a73e8; color: #fff; padding: 24px 28px; border-radius: 8px 8px 0 0; }
  .header h1 { margin: 0 0 4px; font-size: 22px; }
  .header p  { margin: 0; font-size: 13px; opacity: 0.85; }
  .body { background: #fff; padding: 24px 28px; }
  .job-card {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 16px 20px;
    margin-bottom: 14px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .job-info { flex: 1; }
  .job-title { font-size: 16px; font-weight: 700; color: #1a202c; margin: 0 0 4px; }
  .job-meta  { font-size: 13px; color: #555; margin: 0 0 6px; }
  .job-tags  { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    font-size: 11px; font-weight: 600; padding: 3px 8px;
    border-radius: 12px; background: #eef2ff; color: #3730a3;
  }
  .tag.salary { background: #ecfdf5; color: #065f46; }
  .apply-btn {
    display: inline-block;
    background: #1a73e8;
    color: #ffffff !important;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    padding: 9px 18px;
    border-radius: 6px;
    white-space: nowrap;
    margin-top: 4px;
  }
  .footer {
    background: #f7fafc;
    border: 1px solid #e2e8f0;
    border-top: none;
    border-radius: 0 0 8px 8px;
    padding: 14px 28px;
    font-size: 12px;
    color: #888;
    text-align: center;
  }
  .footer a { color: #1a73e8; text-decoration: none; }
</style>
</head>
<body>
<div class="wrap">
  <div class="header">
    <h1>{{ jobs|length }} new job{{ 's' if jobs|length != 1 else '' }}</h1>
    <p>{{ role }} &nbsp;·&nbsp; {{ generated_at.strftime('%b %d, %Y at %H:%M UTC') }}</p>
  </div>

  <div class="body">
    {% for job in jobs %}
    <div class="job-card">
      <div class="job-info">
        <p class="job-title">{{ job.title }}</p>
        <p class="job-meta">
          {{ job.company or 'Unknown company' }}
          {% if job.location %} &nbsp;·&nbsp; {{ job.location }}{% endif %}
        </p>
        <div class="job-tags">
          {% if job.salary %}
            <span class="tag salary">{{ job.salary }}</span>
          {% endif %}
          <span class="tag">{{ loop.index }}</span>
        </div>
      </div>
      <a class="apply-btn" href="{{ job.apply_url or job.eluta_url }}" target="_blank">Apply Now</a>
    </div>
    {% endfor %}
  </div>

  <div class="footer">
    Sourced from <a href="https://www.eluta.ca">eluta.ca</a>
    &nbsp;·&nbsp; Job Search Bot
  </div>
</div>
</body>
</html>
