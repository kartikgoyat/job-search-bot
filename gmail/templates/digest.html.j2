<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  body { margin: 0; padding: 20px; background: #f0f4f8; font-family: Arial, sans-serif; }
  .wrap { max-width: 700px; margin: 0 auto; }
  .header { background: #1a73e8; color: #fff; padding: 24px 28px; border-radius: 8px 8px 0 0; }
  .header h1 { margin: 0 0 4px; font-size: 22px; }
  .header p  { margin: 0; font-size: 13px; opacity: 0.85; }
  .body { background: #fff; padding: 20px 28px; }
  .job-card {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 14px 18px;
    margin-bottom: 12px;
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .job-info { flex: 1; min-width: 0; }
  .job-title { font-size: 15px; font-weight: 700; color: #1a202c; margin: 0 0 3px; }
  .job-meta  { font-size: 13px; color: #555; margin: 0 0 7px; }
  .tags { display: flex; gap: 5px; flex-wrap: wrap; }
  .tag {
    font-size: 11px; font-weight: 600; padding: 2px 8px;
    border-radius: 10px; background: #eef2ff; color: #3730a3;
  }
  .tag.swe    { background: #ede9fe; color: #5b21b6; }
  .tag.da     { background: #ecfdf5; color: #065f46; }
  .tag.ba     { background: #fff7ed; color: #9a3412; }
  .tag.other  { background: #f1f5f9; color: #334155; }
  .tag.salary { background: #f0fdf4; color: #166534; }
  .apply-btn {
    display: inline-block; flex-shrink: 0;
    background: #1a73e8; color: #ffffff !important;
    text-decoration: none; font-size: 13px; font-weight: 600;
    padding: 9px 16px; border-radius: 6px; white-space: nowrap;
    margin-top: 2px;
  }
  .footer {
    background: #f7fafc; border: 1px solid #e2e8f0; border-top: none;
    border-radius: 0 0 8px 8px; padding: 12px 28px;
    font-size: 12px; color: #888; text-align: center;
  }
  .footer a { color: #1a73e8; text-decoration: none; }
</style>
</head>
<body>
<div class="wrap">
  <div class="header">
    <h1>{{ jobs|length }} new job{{ 's' if jobs|length != 1 else '' }}</h1>
    <p>
      {{ roles | map(attribute='name') | join(' · ') }}
      &nbsp;·&nbsp;
      {{ generated_at.strftime('%b %d, %Y at %H:%M UTC') }}
    </p>
  </div>

  <div class="body">
    {% for job in jobs %}
    {% set role_lower = (job.searched_role or '') | lower %}
    <div class="job-card">
      <div class="job-info">
        <p class="job-title">{{ job.title }}</p>
        <p class="job-meta">
          {{ job.company or 'Unknown company' }}
          {% if job.location %}&nbsp;·&nbsp;{{ job.location }}{% endif %}
        </p>
        <div class="tags">
          {% if job.searched_role %}
            {% if 'software' in role_lower or 'engineer' in role_lower %}
              <span class="tag swe">{{ job.searched_role }}</span>
            {% elif 'data analyst' in role_lower or 'data sci' in role_lower %}
              <span class="tag da">{{ job.searched_role }}</span>
            {% elif 'business' in role_lower %}
              <span class="tag ba">{{ job.searched_role }}</span>
            {% else %}
              <span class="tag other">{{ job.searched_role }}</span>
            {% endif %}
          {% endif %}
          {% if job.salary %}
            <span class="tag salary">{{ job.salary }}</span>
          {% endif %}
        </div>
      </div>
      <a class="apply-btn" href="{{ job.apply_url or job.eluta_url }}" target="_blank">Apply Now</a>
    </div>
    {% endfor %}
  </div>

  <div class="footer">
    Sourced from <a href="https://www.eluta.ca">eluta.ca</a>
    &nbsp;·&nbsp; Job Search Bot
  </div>
</div>
</body>
</html>
